<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="HotelSystem.Views.TransactionDialog"
        Title="Транзакция" Height="450" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Добавить транзакцию" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Тип" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeComboBox" Margin="0,0,0,15" Padding="10">
                <ComboBoxItem Content="Доход" Tag="Income"/>
                <ComboBoxItem Content="Расход" Tag="Expense"/>
            </ComboBox>
            <TextBlock Text="Категория" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CategoryComboBox" Margin="0,0,0,15" Padding="10"/>
            <TextBlock Text="Сумма" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="AmountTextBox" Padding="10" Margin="0,0,0,15"/>
            <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Padding="10"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Click="Cancel_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Click="Save_Click" Background="#27AE60" Foreground="White" Padding="20,10" BorderThickness="0">
                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border></ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
