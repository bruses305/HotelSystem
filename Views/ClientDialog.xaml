<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" x:Class="HotelSystem.Views.ClientDialog"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент" Height="500" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#ECF0F1"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Клиент" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="ФИО" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="FullNameTextBox" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Телефон" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTextBox" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Паспорт" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PassportTextBox" Padding="10" Margin="0,0,0,15"/>
                <TextBlock Text="Адрес" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressTextBox" Padding="10" Margin="0,0,0,15"/>
                <CheckBox x:Name="IsVipCheckBox" Content="VIP клиент"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Click="Cancel_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Click="Save_Click" Background="#27AE60" Foreground="White" Padding="20,10" BorderThickness="0">
                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center"/></Border></ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
