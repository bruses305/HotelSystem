<Window x:Class="HotelSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel System" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="5"
                                Margin="5,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A6EA5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="15,15,15,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="15,20,15,30">
                    <TextBlock Text="HOTEL" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
                    <TextBlock Text="System" FontSize="18" Foreground="#3498DB" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="UserRoleText" Text="Роль пользователя" FontSize="11" Foreground="#A0A0A0" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="ОСНОВНОЕ" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="📅 Бронирования" Style="{StaticResource MenuButtonStyle}" Click="NavigateToBookings"/>
                        <Button Content="Номера" Style="{StaticResource MenuButtonStyle}" Click="NavigateToRooms"/>
                        <Button Content="Клиенты" Style="{StaticResource MenuButtonStyle}" Click="NavigateToClients"/>
                        <Button Content="Календарь" Style="{StaticResource MenuButtonStyle}" Click="NavigateToCalendar"/>
                        <Button Content="Оплата услуг" Style="{StaticResource MenuButtonStyle}" Click="NavigateToServicesPayment"/>

                        <TextBlock Text="УПРАВЛЕНИЕ" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Content="Финансы" Style="{StaticResource MenuButtonStyle}" Click="NavigateToFinance"/>
                        <Button Content="Услуги" Style="{StaticResource MenuButtonStyle}" Click="NavigateToServices"/>
                        <Button Content="Сотрудники" Style="{StaticResource MenuButtonStyle}" Click="NavigateToEmployees" x:Name="EmployeesMenuItem"/>
                        <Button Content="Логи" Style="{StaticResource MenuButtonStyle}" Click="NavigateToLogs" x:Name="LogsMenuItem"/>
                        <Button Content="Отчёты" Style="{StaticResource MenuButtonStyle}" Click="NavigateToReports" x:Name="ReportsMenuItem"/>
                        <Button Content="Настройки" Style="{StaticResource MenuButtonStyle}" Click="NavigateToSettings" x:Name="SettingsMenuItem"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="10,10,10,15">
                    <Separator Background="#3A4A5A" Margin="0,0,0,10"/>
                    <Button Content="Выйти" Style="{StaticResource MenuButtonStyle}" Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PageTitle" Text="Бронирования" FontSize="24" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal">
                          <Grid>
                              <Button Content="🔔" FontSize="18" Background="Transparent" BorderThickness="0" Padding="10" Click="ShowNotifications_Click" ToolTip="Уведомления"/>
                              <Ellipse x:Name="NotificationBadge" Width="10" Height="10" Fill="Red" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0" Visibility="Collapsed"/>
                          </Grid>
                          <Button Content="U" FontSize="18" Background="Transparent" BorderThickness="0" Padding="10" Click="ShowProfile_Click" ToolTip="Профиль"/>
                      </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Margin="0"/>
        </Grid>
    </Grid>
</Window>
