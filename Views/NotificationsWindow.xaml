<Window x:Class="HotelSystem.Views.NotificationsWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Уведомления" Height="500" Width="500"
 WindowStartupLocation="CenterOwner"
 Background="#ECF0F1">
<Grid Margin="20">
<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
<RowDefinition Height="Auto"/>
</Grid.RowDefinitions>
        
<TextBlock Text="Уведомления" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        
<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
<Button Content="Прочитать все" Click="MarkAllRead_Click" Padding="10,5" Margin="0,0,10,0" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
<Button.Template>
<ControlTemplate TargetType="Button">
<Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
<ContentPresenter/>
</Border>
</ControlTemplate>
</Button.Template>
</Button>
<Button Content="Удалить все" Click="DeleteAll_Click" Padding="10,5" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
<Button.Template>
<ControlTemplate TargetType="Button">
<Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
<ContentPresenter/>
</Border>
</ControlTemplate>
</Button.Template>
</Button>
</StackPanel>
        
<Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
<ScrollViewer VerticalScrollBarVisibility="Auto">
<ItemsControl x:Name="NotificationsList">
<ItemsControl.ItemTemplate>
<DataTemplate>
<Border Padding="12" Margin="0,0,0,8" CornerRadius="6" BorderThickness="1">
<Border.Style>
<Style TargetType="Border">
<Setter Property="Background" Value="#F8F9FA"/>
<Setter Property="BorderBrush" Value="#DEE2E6"/>
<Style.Triggers>
<DataTrigger Binding="{Binding IsRead}" Value="False">
<Setter Property="Background" Value="#E3F2FD"/>
<Setter Property="BorderBrush" Value="#2196F3"/>
</DataTrigger>
<DataTrigger Binding="{Binding IsRead}" Value="True">
<Setter Property="Background" Value="#E8E8E8"/>
<Setter Property="Opacity" Value="0.7"/>
</DataTrigger>
</Style.Triggers>
</Style>
</Border.Style>
<Grid>
<Grid.ColumnDefinitions>
<ColumnDefinition Width="Auto"/>
<ColumnDefinition Width="*"/>
<ColumnDefinition Width="Auto"/>
</Grid.ColumnDefinitions>
            
<!-- Кнопка перехода к бронированию (кружок / галочка) -->
<Button Grid.Column="0" Click="GoToBooking_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="5" Margin="0,0,10,0" VerticalAlignment="Center" ToolTip="Перейти к бронированию">
<Button.Style>
<Style TargetType="Button">
<Setter Property="Visibility" Value="Visible"/>
<Style.Triggers>
<DataTrigger Binding="{Binding BookingId}" Value="{x:Null}">
<Setter Property="Visibility" Value="Collapsed"/>
</DataTrigger>
</Style.Triggers>
</Style>
</Button.Style>
<TextBlock FontSize="16">
<TextBlock.Style>
<Style TargetType="TextBlock">
<Setter Property="Text" Value="○"/>
<Setter Property="Foreground" Value="#3498DB"/>
<Style.Triggers>
<DataTrigger Binding="{Binding IsRead}" Value="True">
<Setter Property="Text" Value="✓"/>
<Setter Property="Foreground" Value="#27AE60"/>
</DataTrigger>
</Style.Triggers>
</Style>
</TextBlock.Style>
</TextBlock>
</Button>
            
<StackPanel Grid.Column="1">
<TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontWeight="SemiBold"/>
<TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Foreground="#7F8C8D" FontSize="11" Margin="0,4,0,0"/>
</StackPanel>
            
<!-- Кнопка удаления -->
<Button Grid.Column="2" Content="✕" Click="Delete_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0" Padding="8,4" Foreground="#E74C3C" FontSize="14" VerticalAlignment="Top" ToolTip="Удалить уведомление" Cursor="Hand"/>
</Grid>
</Border>
</DataTemplate>
</ItemsControl.ItemTemplate>
</ItemsControl>
</ScrollViewer>
</Border>
        
<Button Grid.Row="3" Content="Закрыть" Click="Close_Click" Padding="20,8" HorizontalAlignment="Right" Margin="0,15,0,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand">
<Button.Template>
<ControlTemplate TargetType="Button">
<Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
<ContentPresenter/>
</Border>
</ControlTemplate>
</Button.Template>
</Button>
</Grid>
</Window>
