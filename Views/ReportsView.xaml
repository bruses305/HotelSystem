<Page x:Class="HotelSystem.Views.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      Background="#ECF0F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <DatePicker x:Name="StartDatePicker" Width="120" Margin="0,0,10,0"/>
                    <TextBlock Text=" - " VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="EndDatePicker" Width="120" Margin="0,0,20,0"/>
                    <Button Content="Сформировать" Click="GenerateReport_Click" Background="#3498DB" Foreground="White" Padding="15,5" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="OpenLastExportBtn" Content="Открыть" Click="OpenLastExport_Click" Background="#95A5A6" Foreground="White" Padding="15,5" Margin="0,0,10,0" BorderThickness="0" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Экспорт Excel" Click="ExportExcel_Click" Background="#27AE60" Foreground="White" Padding="15,5" Margin="0,0,10,0" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Сохранить графики" Click="ExportCharts_Click" Background="#9B59B6" Foreground="White" Padding="15,5" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Карточки с итогами -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Доходы" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalIncomeText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Расходы" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalExpensesText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Прибыль" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ProfitText" Text="0 ₽" FontSize="20" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Бронирований" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="BookingsCountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="Загрузка" FontSize="12" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OccupancyText" Text="0%" FontSize="20" FontWeight="Bold" Foreground="#F39C12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Графики и таблицы -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            
            <!-- Загрузка отеля -->
            <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,7,7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Загрузка отеля" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <oxy:PlotView x:Name="OccupancyChart" Grid.Row="1"/>
                </Grid>
            </Border>
            
            <!-- Доходы по месяцам/дням -->
            <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="7,0,0,7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="IncomeChartTitle" Text="Доходы по месяцам" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" VerticalAlignment="Center"/>
                        <Button x:Name="SwitchChartBtn" Grid.Column="1" Content="По дням" Click="SwitchChart_Click" 
                                Background="#3498DB" Foreground="White" Padding="10,5" BorderThickness="0" Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <oxy:PlotView x:Name="IncomeChart" Grid.Row="1"/>
                </Grid>
            </Border>
            
            <!-- Прибыльность номеров -->
            <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,7,7,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Прибыльность номеров" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="RoomProfitGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="Доход" Binding="{Binding Income, StringFormat=N0}" Width="90"/>
                            <DataGridTextColumn Header="Расходы" Binding="{Binding Expenses, StringFormat=N0}" Width="90"/>
                            <DataGridTextColumn Header="Прибыль" Binding="{Binding Profit, StringFormat=N0}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            
            <!-- Топ клиенты -->
            <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="7,7,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Топ клиенты" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid x:Name="TopClientsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" Background="White" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Бронирований" Binding="{Binding BookingsCount}" Width="90"/>
                            <DataGridTextColumn Header="Потрачено" Binding="{Binding TotalSpent, StringFormat=N0}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
