<Page x:Class="HotelSystem.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#ECF0F1">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="8" Padding="30">
            <StackPanel MaxWidth="500">
                <TextBlock Text="Настройки системы" FontSize="24" FontWeight="Bold" Margin="0,0,0,30"/>

                <!-- Настройки отеля -->
                <TextBlock Text="Информация об отеле" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                
                <TextBlock Text="Название отеля" Margin="0,0,0,5"/>
                <TextBox x:Name="HotelNameTextBox" Text="Hotel System" Padding="10" Margin="0,0,0,15"/>

                <TextBlock Text="Адрес" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressTextBox" Padding="10" Margin="0,0,0,15"/>

                <TextBlock Text="Телефон" Margin="0,0,0,5"/>
                <TextBox x:Name="PhoneTextBox" Padding="10" Margin="0,0,0,15"/>

                <!-- Настройки логирования -->
                <TextBlock Text="Логирование" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,15"/>
                
                <TextBlock Text="Хранить логи (дней):" Margin="0,0,0,5"/>
                <TextBox x:Name="LogRetentionTextBox" Text="30" Padding="10" Margin="0,0,0,10" Width="100" HorizontalAlignment="Left"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                    <Button Content="Сохранить настройки" Click="SaveSettings_Click" Background="#27AE60" Foreground="White" Padding="20,10" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Сбросить" Click="ResetSettings_Click" Padding="20,10" Margin="15,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
